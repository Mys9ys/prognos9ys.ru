# Cursor index exclusions — меньше RAM, меньше шума в поиске и у агента.
# Синтаксис как у .gitignore. Негация (!) возвращает путь в индекс.
#
# ОСТАЁТСЯ в индексе (рабочий код):
#   frontend/src/{components,pages,store,api,router,config,utils}/
#   local/modules/prognos9ys.main/lib/
#   local/mob_app_ajax/ajax/          — исходники PHP-эндпоинтов mob_app
#   local/components/, local/classes/
#   local/php_interface/migrations/*.php
#   .cursor/rules/

# =============================================================================
# Bitrix / зависимости / медиа на диске
# =============================================================================
/bitrix/
/upload/
/vendor/
/test/

# =============================================================================
# IDE / OSPanel (локальная среда, не код проекта)
# =============================================================================
.idea/
.vscode/
.gigaide/
.gigacode/
.osp/

# =============================================================================
# Frontend: артефакты сборки и бинарные ассеты
# =============================================================================
/frontend/node_modules/
/frontend/dist/
/frontend/src/assets/
/frontend/public/

# =============================================================================
# mob_app: собранный Vue-бандл (исходники — frontend/, PHP — local/mob_app_ajax/ajax/)
# =============================================================================
/mob_app/

# =============================================================================
# local/tools: одноразовые диагностики, генераторы, дампы (сотни MB)
# При необходимости — открывать файл по явному пути
# =============================================================================
/local/tools/

# =============================================================================
# Миграции: XML-дампы элементов инфоблоков (PHP-файлы миграций остаются)
# =============================================================================
/local/php_interface/migrations/*_files/
/local/php_interface/archive/

# =============================================================================
# Шаблоны Bitrix: скомпилированные стили и статика компонентов
# =============================================================================
/local/templates/**/assets/
/local/templates/**/font-awesome-4.7.0/
/local/components/**/assets/
/local/components/**/style.min.css
/local/components/**/style.css

# =============================================================================
# Тестовые/временные файлы модуля
# =============================================================================
/local/modules/prognos9ys.main/test_*.php
/local/modules/prognos9ys.main/verify_*.php

# =============================================================================
# Дампы БД и отладочные JSON
# =============================================================================
**/*.sql
**/*.sql.gz
**/*.sql.bz2
**/debug_request*.json
**/set_debug_request.json
**/tmp_*.json
**/tmp_api_*.json

# =============================================================================
# Мусор в корне репозитория
# =============================================================================
composer.phar
/fix_*.php
/fix_tools.php
/prog_lech.php
/.htaccess.restore
/sitemap*.xml
/robots.txt
/test_*.png
/yandex_*.html
